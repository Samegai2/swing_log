<header>
  <nav>
    <%= link_to "Swing Log", root_path %>
    <%= link_to "About", about_path %>
    <%= link_to "投稿一覧", posts_path %>

    <% if Current.session&.user %>
      <%= link_to "マイページ", user_path(Current.session.user) %>
