<h1>投稿一覧</h1>

<div class="page-actions">
  <%= link_to "新規投稿", new_post_path, class: "btn" %>
</div>

<div class="post-list">
  <% @posts.each do |post| %>
    <div class="post-card">

      <% if post.image.attached? %>
        <div class="post-image">
          <%= image_tag post.image, width: 250 %>
        </div>
      <% end %>

      <h2>
        <%= link_to post.title, post_path(post) %>
      </h2>

      <p><strong>投稿者：</strong><%= post.user&.name || "投稿者不明" %></p>
      <p><strong>施設名：</strong><%= post.facility_name %></p>
      <p><strong>住所：</strong><%= post.address %></p>
      <p><strong>種別：</strong><%= post.play_style_i18n %></p>
      <p><strong>スコア：</strong><%= post.score %></p>
      <p><strong>感想：</strong><%= truncate(post.body, length: 100) %></p>

    </div>
  <% end %>
</div>
