<div class="post-card">

  <h1><%= @post.title %></h1>

  <% if @post.image.attached? %>
    <div class="post-image">
      <%= image_tag @post.image, width: 500 %>
    </div>
  <% end %>

  <p><strong>投稿者：</strong><%= @post.user&.name || "投稿者不明" %></p>
  <p><strong>施設名：</strong><%= @post.facility_name %></p>
  <p><strong>住所：</strong><%= @post.address %></p>
  <p><strong>種別：</strong><%= @post.play_style_i18n %></p>
  <p><strong>スコア：</strong><%= @post.score %></p>
  <p><strong>感想：</strong><%= simple_format(@post.body) %></p>

  <% if Current.session&.user == @post.user %>
    <div class="post-actions">
      <%= link_to "編集", edit_post_path(@post), class: "btn" %>

      <%= link_to "削除",
          post_path(@post),
          data: {
            turbo_method: :delete,
            turbo_confirm: "本当に削除しますか？"
          },
          class: "btn btn-danger" %>
    </div>
  <% end %>

</div>

<div class="back-link">
  <%= link_to "投稿一覧へ戻る", posts_path %>
</div>
